 
<section id="stats-reviews" aria-label="Statistiques et avis clients">

  <div class="stats-wrap">
    <h2 class="section-title">Nos chiffres</h2>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-number"><span class="counter" data-target="1250">0</span>+</div>
        <div class="stat-label">Clients</div>
      </div>

      <div class="stat-card">
        <div class="stat-number"><span class="counter" data-target="8420">0</span></div>
        <div class="stat-label">Colis expédiés</div>
      </div>

      <div class="stat-card">
        <div class="stat-number"><span class="counter" data-target="34">0</span></div>
        <div class="stat-label">Sites partenaires</div>
      </div>
    </div>
    <p class="small-note">Chiffres mis à jour automatiquement — modifie les attributs <code>data-target</code>.</p>
  </div>

  <!-- REVIEWS -->
  <div class="reviews-wrap" aria-label="Avis clients">
    <h2 class="section-title">Avis de nos clients</h2>

    <div class="reviews-slider" id="reviewsSlider">
      <!-- Les slides seront insérées par JS à partir du tableau "reviews" -->
    </div>

    <div class="reviews-controls">
      <button class="rv-btn" id="prevBtn" aria-label="Avis précédent">‹</button>
      <div class="dots" id="dots"></div>
      <button class="rv-btn" id="nextBtn" aria-label="Avis suivant">›</button>
    </div>

    <p class="small-note">Clique sur les flèches ou laisse le slider défiler automatiquement.</p>
  </div>

</section>



<style>
  /* --- container --- */
  #stats-reviews { max-width:1100px; margin:40px auto; padding:20px; font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial; color:#222; }

  .section-title { text-align:center; font-size:1.6rem; margin:10px 0 20px; color:#1a1a1a; }

  /* --- stats --- */
  .stats-grid { display:flex; gap:20px; justify-content:center; align-items:stretch; flex-wrap:wrap; }
  .stat-card { background:#fff; padding:22px 26px; border-radius:12px; box-shadow: 0 6px 18px rgba(0,0,0,0.06); width:220px; text-align:center; }
  .stat-number { font-size:2rem; font-weight:700; color:#e07a00; }
  .stat-label { color:#555; margin-top:6px; font-weight:600; }

  .small-note { text-align:center; color:#777; font-size:0.9rem; margin-top:10px; }

  /* --- reviews --- */
  .reviews-wrap { margin-top:40px; }
  .reviews-slider { position:relative; overflow:hidden; padding:10px 0; min-height:170px; }
  .rv-track { display:flex; gap:18px; transition:transform 450ms ease; will-change:transform; padding:10px; }
  .rv-card { min-width:320px; max-width:420px; background:#fff; padding:16px; border-radius:10px; box-shadow:0 6px 18px rgba(0,0,0,0.06); display:flex; flex-direction:column; gap:8px; }
  .rv-author { font-weight:700; }
  .rv-text { color:#444; font-size:0.95rem; line-height:1.35; }
  .rv-meta { display:flex; justify-content:space-between; align-items:center; color:#666; font-size:0.9rem; }

  /* stars */
  .stars { color:#f1c40f; font-weight:700; letter-spacing:2px; }

  /* controls */
  .reviews-controls { display:flex; justify-content:center; align-items:center; gap:12px; margin-top:12px; }
  .rv-btn { background:#fff; border:1px solid #ddd; padding:8px 12px; border-radius:6px; cursor:pointer; font-size:18px; }
  .rv-btn:focus { outline:3px solid rgba(64,128,255,0.15); }

  .dots { display:flex; gap:8px; align-items:center; }
  .dot { width:10px; height:10px; border-radius:50%; background:#ddd; cursor:pointer; }
  .dot.active { background:#1a73e8; }

  /* responsive */
  @media (max-width:760px){
    .stat-card { width:44%; }
    .rv-card { min-width:260px; }
  }
  @media (max-width:420px){
    .stat-card { width:100%; }
    .rv-card { min-width:100%; max-width:100%; }
  }
</style>


<script>
  /* -------------------------------
     Animated counters (clients/colis/sites)
     ------------------------------- */
  (function countersInit(){
    const counters = document.querySelectorAll('.counter');
    const speedBase = 180; // augmente pour animer plus lentement

    if(!counters.length) return;

    const animateCounter = (el) => {
      const target = parseInt(el.getAttribute('data-target').replace(/\D/g,''), 10) || 0;
      const start = 0;
      const duration = Math.max(600, speedBase * Math.log10(Math.max(10,target))); // durée approximative
      const startTime = performance.now();

      function step(now){
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        // easeOutCubic
        const ease = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(start + (target - start) * ease);
        el.textContent = current.toLocaleString('fr-FR');
        if(progress < 1) requestAnimationFrame(step);
        else el.textContent = target.toLocaleString('fr-FR');
      }
      requestAnimationFrame(step);
    };

    const io = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          animateCounter(entry.target);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    counters.forEach(c => io.observe(c));
  })();

  /* -------------------------------
     Reviews slider
     - Data: modifie le tableau "reviews"
     - Auto-play + boutons + points
     ------------------------------- */
  (function reviewsInit(){
    const reviews = [
      { name: "Marie T.",   rating:5, text:"Service rapide, colis reçu en parfait état. Merci Holy Shop !", origin:"Paris" },
      { name: "Jean P.",    rating:4, text:"Bon suivi et communication. Petit retard sur l'affranchissement mais globalement satisfait.", origin:"Brazzaville" },
      { name: "Amina K.",   rating:5, text:"Très professionnel, commandes groupées bien organisées.", origin:"Pointe-Noire" },
      { name: "Olivier S.", rating:5, text:"Prix compétitifs et livraison fiable. Je recommande.", origin:"Lyon" },
      { name: "Fatou B.",   rating:4, text:"Facile à utiliser, service client réactif.", origin:"Dolisie" }
    ];

    const container = document.getElementById('reviewsSlider');
    if(!container) return;

    // Build track + cards
    const track = document.createElement('div');
    track.className = 'rv-track';
    reviews.forEach(r => {
      const card = document.createElement('article');
      card.className = 'rv-card';
      card.setAttribute('aria-label', Avis de ${r.name});

      const stars = '★'.repeat(r.rating) + '☆'.repeat(Math.max(0,5-r.rating));
      card.innerHTML = `
        <div class="rv-meta">
          <div class="rv-author">${escapeHtml(r.name)}</div>
          <div class="stars" aria-hidden="true">${stars}</div>
        </div>
        <div class="rv-text">${escapeHtml(r.text)}</div>
        <div class="rv-meta"><small>${escapeHtml(r.origin)}</small></div>
      `;
      track.appendChild(card);
    });

    // duplicate nodes to allow smooth loop feel if many cards
    container.appendChild(track);

    // controls
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const dotsWrap = document.getElementById('dots');

    // state
    let index = 0;
    const slides = Array.from(track.children);
    const slideCount = slides.length;
    const visibleCount = calculateVisibleCount();
    let autoplayTimer = null;
    const autoplayDelay = 4500;

    // create dots
    for(let i=0;i<slideCount;i++){
      const dot = document.createElement('div');
      dot.className = 'dot';
      dot.dataset.i = i;
      dot.addEventListener('click', () => { goTo(parseInt(dot.dataset.i,10)); resetAutoplay(); });
      dotsWrap.appendChild(dot);
    }

    function calculateVisibleCount(){
      if(window.innerWidth < 420) return 1;
      if(window.innerWidth < 760) return 1;
      return 2; // show two cards side-by-side on large screens
    }

    function update(){
      const cardWidth = slides[0].getBoundingClientRect().width + 18; // card + gap
      const offset = index * cardWidth;
      track.style.transform = translateX(${-offset}px);
      // active dot
      Array.from(dotsWrap.children).forEach(d => d.classList.remove('active'));
      const activeDot = dotsWrap.children[index % slideCount];
      if(activeDot) activeDot.classList.add('active');
    }

    function goTo(i){
      index = ((i % slideCount) + slideCount) % slideCount;
      update();
    }
    function next(){ goTo(index + 1); }
    function prev(){ goTo(index - 1); }

    prevBtn.addEventListener('click', () => { prev(); resetAutoplay(); });
    nextBtn.addEventListener('click', () => { next(); resetAutoplay(); });

    // autoplay
    function startAutoplay(){
      stopAutoplay();
      autoplayTimer = setInterval(() => { next(); }, autoplayDelay);
    }
    function stopAutoplay(){ if(autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; } }
    function resetAutoplay(){ stopAutoplay(); startAutoplay(); }

    // responsive recalculation
    window.addEventListener('resize', () => {
      update();
    });

    // initial render + start
    update();
    startAutoplay();

    // helper: escape HTML
    function escapeHtml(str){
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    // pause on hover for accessibility
    container.addEventListener('mouseenter', stopAutoplay);
    container.addEventListener('mouseleave', startAutoplay);

  })();
</script>
